{
  "name": "dropscout-functions",
  "version": "1.0.0",
  "description": "DropScout TR — Firebase Cloud Functions (2nd gen) backend",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google-cloud/kms": "^5.4.0",
    "@sentry/node": "^10.50.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/xml2js": "^0.4.14",
    "typescript": "^5.7.3"
  },
  "private": true
}
