# ═══════════════════════════════════════════════════════════════════
# DropScout TR — Çevre Değişkenleri Şablonu
# ═══════════════════════════════════════════════════════════════════
# Bu dosya commit'lenir; gerçek değerler İÇERMEZ. Yerel geliştirme
# için kopyala: `cp .env.example .env.local` (Vite tarafı için).
# Backend secret'ları Firebase Secret Manager'da tutulur — aşağıda
# `firebase functions:secrets:set ...` komutları listelenmiştir.
# ═══════════════════════════════════════════════════════════════════


# ─── Frontend (Vite) ────────────────────────────────────────────────
# Not: src/js/firebase-config.js içinde Firebase web config halen
# sabit yazılı. Public client config olduğu için secret değildir;
# yine de farklı projeye bağlanmak isteyenler aşağıdaki değişkenleri
# kullanabilir (firebase-config.js'i Vite env'den okuyacak şekilde
# güncellemek gerekir).

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=dropscoutapp.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=dropscoutapp
# VITE_FIREBASE_STORAGE_BUCKET=dropscoutapp.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Sentry (frontend) — production hata izleme
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=


# ═══════════════════════════════════════════════════════════════════
# Backend secret'ları — Firebase Secret Manager
# ─────────────────────────────────────────────────────────────────
# Aşağıdaki secret'lar `defineSecret(...)` ile functions/src/lib/*.ts
# içinde tanımlıdır. Set komutu:
#
#   firebase functions:secrets:set <NAME>
#   firebase functions:secrets:get <NAME>     # değeri görmek için
#   firebase functions:secrets:destroy <NAME> # silmek için
#
# Deploy:
#   firebase deploy --only functions
# ═══════════════════════════════════════════════════════════════════

# ─── AI ─────────────────────────────────────────────────────────────
# Claude Haiku 4.5 (claude-haiku-4-5-20251001)
# firebase functions:secrets:set CLAUDE_API_KEY
CLAUDE_API_KEY=

# ─── Sentry (backend) ───────────────────────────────────────────────
# firebase functions:secrets:set SENTRY_DSN
SENTRY_DSN=

# ─── Alert webhook (Discord/Slack) ──────────────────────────────────
# firebase functions:secrets:set ALERT_WEBHOOK_URL
ALERT_WEBHOOK_URL=

# ─── Apify ──────────────────────────────────────────────────────────
# Tedarikçi Bul + Asya Gap Radar aktörleri
# firebase functions:secrets:set APIFY_TOKEN
APIFY_TOKEN=
APIFY_GAP_ACTOR_ID=          # legacy — TR pazaryeri Gap (kullanılmıyor)
APIFY_SUPPLIER_ACTOR_ID=     # Alibaba/AliExpress tedarikçi arama

# Asya kaynaklar — yeni Gap Radar pivot (docs/architecture.md §5)
APIFY_DOUYIN_ACTOR_ID=       # Çin Douyin (TikTok TR)
APIFY_XIAOHONGSHU_ACTOR_ID=  # Çin Xiaohongshu (RedNote)
APIFY_TAOBAO_ACTOR_ID=       # Çin Taobao/Tmall daily ranking
APIFY_COUPANG_ACTOR_ID=      # Güney Kore Coupang Best
APIFY_RAKUTEN_ACTOR_ID=      # Japonya Rakuten ranking
APIFY_MERCARI_JP_ACTOR_ID=   # Japonya Mercari hot items

# ─── Google Trends (SerpAPI) ────────────────────────────────────────
# firebase functions:secrets:set SERPAPI_KEY
SERPAPI_KEY=

# ─── Ödeme sağlayıcı (lansman öncesi finalize) ──────────────────────
# Aktif sağlayıcı seçilince ilgili secret set edilir.
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://api.iyzipay.com   # sandbox: https://sandbox-api.iyzipay.com
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=

# ─── KMS (envelope encryption) ──────────────────────────────────────
# Not: Şifreleme anahtarı Google Cloud KMS'te saklanır, env değişkeni
# OLARAK SETLENMEZ. functions/src/lib/crypto.ts otomatik bağlanır:
#   projects/<PROJECT_ID>/locations/europe-west1/
#     keyRings/dropscout-keys/cryptoKeys/dropscout-credentials-kek
#
# İlk kurulum (bir kerelik):
#   gcloud kms keyrings create dropscout-keys \
#     --location=europe-west1
#   gcloud kms keys create dropscout-credentials-kek \
#     --keyring=dropscout-keys --location=europe-west1 \
#     --purpose=encryption --rotation-period=90d \
#     --next-rotation-time=$(date -u -d "+90 days" +%Y-%m-%dT%H:%M:%SZ)
#   gcloud kms keys add-iam-policy-binding dropscout-credentials-kek \
#     --keyring=dropscout-keys --location=europe-west1 \
#     --member=serviceAccount:<PROJECT_NUMBER>-compute@developer.gserviceaccount.com \
#     --role=roles/cloudkms.cryptoKeyEncrypterDecrypter
